<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="vboxMainContent" prefHeight="600.0" prefWidth="817.0" style="-fx-background-color: #F4F4F4;" styleClass="admin-page-root" stylesheets="@../../CSS/admin.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.PengeluaranController">
    <children>
        <HBox alignment="CENTER_LEFT" maxHeight="60.0" minHeight="60.0" prefHeight="60.0" styleClass="admin-header">
            <children>
                <Label fx:id="lblTitle" styleClass="admin-title" text="Kelola Pengeluaran">
                    <font><Font name="System Bold" size="24.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Label>
            </children>
        </HBox>

        <VBox minHeight="0.0" spacing="20.0" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="20.0" left="25.0" right="25.0" top="20.0" /></padding>
            <children>
                <HBox fx:id="hboxSearch" alignment="CENTER_LEFT" maxHeight="80.0" minHeight="80.0" prefHeight="80.0" spacing="15.0" styleClass="admin-search-card">
                    <padding><Insets left="20.0" right="20.0" /></padding>
                    <children>
                        <TextField fx:id="txtSearchPengeluaran" prefHeight="35.0" prefWidth="500.0" promptText="Cari data pengeluaran..." styleClass="admin-input" HBox.hgrow="ALWAYS" />
                        <DatePicker fx:id="dpFilterTanggal" prefHeight="35.0" prefWidth="200.0" promptText="Filter Tanggal" styleClass="admin-date-picker" />
                        <Button fx:id="btnSearch" mnemonicParsing="false" onAction="#handleCariPengeluaran" prefHeight="35.0" prefWidth="100.0" styleClass="admin-button-primary" text="Cari" />
                    </children>
                </HBox>

                <VBox fx:id="LyrPengeluaran" minHeight="0.0" spacing="15.0" styleClass="admin-table-card" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" maxHeight="35.0" minHeight="35.0" prefHeight="35.0">
                            <children>
                                <Label fx:id="lblSubTitle" styleClass="admin-section-title" text="Riwayat Pengeluaran" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnTambahPengeluaran" maxHeight="35.0" maxWidth="240.0" minHeight="35.0" minWidth="240.0" mnemonicParsing="false" onAction="#handleTambahPengeluaran" prefHeight="35.0" prefWidth="240.0" styleClass="admin-button-primary" text="+ Tambahkan Data Pengeluaran" />
                            </children>
                        </HBox>

                        <HBox fx:id="hboxTableHead" alignment="CENTER_LEFT" maxHeight="40.0" minHeight="40.0" prefHeight="40.0" spacing="10.0" styleClass="admin-table-head">
                            <padding><Insets left="15.0" right="15.0" /></padding>
                            <children>
                                <Label fx:id="No" prefWidth="40.0" style="-fx-font-weight: bold;" text="No" />
                                <Label fx:id="lblSortIdPengeluaran" prefWidth="125.0" style="-fx-font-weight: bold;" text="ID Pengeluaran" />
                                <Label fx:id="lblSortTanggal" prefWidth="110.0" style="-fx-font-weight: bold;" text="Tanggal" />
                                <Label fx:id="lblSortNominal" prefWidth="130.0" style="-fx-font-weight: bold;" text="Nominal" />
                                <Label fx:id="lblSortJenis" prefWidth="120.0" style="-fx-font-weight: bold;" text="Jenis" />
                                <Label fx:id="lblSortIdUser" prefWidth="100.0" style="-fx-font-weight: bold;" text="ID User" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label alignment="CENTER" prefWidth="160.0" style="-fx-font-weight: bold;" text="Aksi" />
                            </children>
                        </HBox>

                        <ScrollPane fx:id="scrollPengeluaran" fitToWidth="true" hbarPolicy="NEVER" minHeight="0.0" styleClass="admin-list-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="vboxPengeluaranList" spacing="8.0" style="-fx-background-color: transparent;">
                                </VBox>
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
