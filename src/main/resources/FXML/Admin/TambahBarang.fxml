<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="paneRoot" prefHeight="650.0" prefWidth="917.0" style="-fx-background-color: #F4F4F4;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.TambahBarangController">
    <children>
        <HBox fx:id="hboxHeader" alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #4A76A8;">
            <children>
                <Label fx:id="lblTitle" text="Tambahkan Barang Baru" textFill="WHITE">
                    <font><Font name="System Bold" size="24.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Label>
            </children>
        </HBox>

        <VBox alignment="TOP_CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
            <children>
                <VBox fx:id="vboxFormCard" maxWidth="850.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 8);">
                    <children>
                        <GridPane hgap="30.0" vgap="20.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="50.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="50.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="50.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label fx:id="lblIdBarang" style="-fx-font-family: 'Inter Medium'; -fx-font-size: 13;" text="ID Barang" />
                                        <TextField fx:id="txtIdBarang" prefHeight="38.0" promptText="Masukkan ID Barang" style="-fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" GridPane.columnIndex="1">
                                    <children>
                                        <Label fx:id="lblNamaBarang" style="-fx-font-family: 'Inter Medium'; -fx-font-size: 13;" text="Nama Barang" />
                                        <TextField fx:id="txtNamaBarang" prefHeight="38.0" promptText="Masukkan Nama Barang" style="-fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" GridPane.rowIndex="1">
                                    <children>
                                        <Label fx:id="lblIdKategori" style="-fx-font-family: 'Inter Medium'; -fx-font-size: 13;" text="ID Kategori" />
                                        <ComboBox fx:id="cmbKategori" maxWidth="Infinity" prefHeight="38.0" promptText="Pilih Kategori" style="-fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8;" />
                                    </children>
                                </VBox>
                                <HBox spacing="15.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblStok" style="-fx-font-family: 'Inter Medium'; -fx-font-size: 13;" text="Stok" />
                                                <TextField fx:id="txtStok" prefHeight="38.0" promptText="Masukkan Stok" style="-fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <VBox spacing="5.0" GridPane.rowIndex="2">
                                    <children>
                                        <Label fx:id="lblHargaBeli" style="-fx-font-family: 'Inter Medium'; -fx-font-size: 13;" text="Harga Beli" />
                                        <TextField fx:id="txtHargaBeli" prefHeight="38.0" promptText="Masukkan Harga Beli" style="-fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8;" />
                                    </children>
                                </VBox>
                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <children>
                                        <Label fx:id="lblHargaJual" style="-fx-font-family: 'Inter Medium'; -fx-font-size: 13;" text="Harga Jual" />
                                        <TextField fx:id="txtHargaJual" prefHeight="38.0" promptText="Masukkan Harga Jual" style="-fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8;" />
                                    </children>
                                </VBox>
                            </children>
                            <VBox.margin><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></VBox.margin>
                        </GridPane>

                        <HBox fx:id="hboxFooter" alignment="CENTER" prefHeight="90.0" spacing="20.0" style="-fx-background-color: #F9FAFB; -fx-background-radius: 0 0 15 15;">
                            <children>
                                <Button fx:id="btnBatal" onAction="#handleBatal" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #E5E7EB; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-font-family: 'Inter Medium'; -fx-cursor: hand;" text="Batal" />
                                <Button fx:id="btnTambah" onAction="#handleSimpan" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #5CB85C; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-family: 'Inter Medium'; -fx-cursor: hand;" text="+  Tambahkan Barang" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
