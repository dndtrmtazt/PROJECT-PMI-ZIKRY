<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ExportSuccessDialogController">
    <styleClass>
        <String fx:value="export-dialog-root" />
        <String fx:value="export-success-root" />
    </styleClass>
    <children>
        <VBox prefHeight="350.0" prefWidth="560.0">
            <styleClass>
                <String fx:value="export-dialog-card" />
                <String fx:value="export-success-card" />
            </styleClass>
            <children>
                <HBox alignment="CENTER_LEFT" minHeight="64.0" prefHeight="64.0" spacing="13.0" styleClass="export-dialog-header">
                    <padding>
                        <Insets left="28.0" right="24.0" />
                    </padding>
                    <children>
                        <StackPane maxHeight="32.0" maxWidth="32.0" minHeight="32.0" minWidth="32.0" prefHeight="32.0" prefWidth="32.0" styleClass="export-success-header-icon">
                            <children>
                                <Label text="✓" styleClass="export-success-header-check" />
                            </children>
                        </StackPane>
                        <Label text="Export Berhasil" styleClass="export-dialog-title" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnClose" mnemonicParsing="false" onAction="#handleClose" text="X">
                            <styleClass>
                                <String fx:value="export-dialog-close" />
                                <String fx:value="export-success-close" />
                            </styleClass>
                        </Button>
                    </children>
                </HBox>

                <VBox alignment="CENTER_LEFT" minHeight="210.0" prefHeight="210.0" spacing="14.0" styleClass="export-success-body">
                    <padding>
                        <Insets bottom="18.0" left="28.0" right="28.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="16.0">
                            <children>
                                <StackPane maxHeight="62.0" maxWidth="62.0" minHeight="62.0" minWidth="62.0" prefHeight="62.0" prefWidth="62.0" styleClass="export-success-check-circle">
                                    <children>
                                        <Label text="✓" styleClass="export-success-check-text" />
                                    </children>
                                </StackPane>
                                <VBox alignment="CENTER_LEFT" spacing="7.0">
                                    <children>
                                        <Label text="Laporan berhasil disimpan" styleClass="export-success-heading" />
                                        <Label text="Laporan Anda telah berhasil diekspor dan disimpan." styleClass="export-success-description" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="export-success-path-box">
                            <padding>
                                <Insets bottom="10.0" left="12.0" right="12.0" top="10.0" />
                            </padding>
                            <children>
                                <Label fx:id="lblFormatBadge" text="PDF" />
                                <Label fx:id="lblPath" maxWidth="420.0" text="C:\Users\Yllnore\Downloads\laporan.pdf" styleClass="export-success-path-text" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="export-success-info-row">
                            <children>
                                <StackPane maxHeight="22.0" maxWidth="22.0" minHeight="22.0" minWidth="22.0" prefHeight="22.0" prefWidth="22.0" styleClass="export-success-info-icon">
                                    <children>
                                        <Label text="i" styleClass="export-success-info-icon-text" />
                                    </children>
                                </StackPane>
                                <Label fx:id="lblInfo" text="File telah disimpan dalam format PDF." styleClass="export-success-info-text" wrapText="true" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" minHeight="76.0" prefHeight="76.0" styleClass="export-dialog-footer">
                    <padding>
                        <Insets left="26.0" right="26.0" />
                    </padding>
                    <children>
                        <Button fx:id="btnOk" mnemonicParsing="false" onAction="#handleOk" prefHeight="42.0" prefWidth="118.0" styleClass="export-success-ok-button" text="OK" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
