<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="export-dialog-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ExportLaporanDialogController">
    <children>
        <VBox prefHeight="288.0" prefWidth="560.0" styleClass="export-dialog-card">
            <children>
                <HBox alignment="CENTER_LEFT" minHeight="64.0" prefHeight="64.0" spacing="13.0" styleClass="export-dialog-header">
                    <padding>
                        <Insets left="28.0" right="24.0" />
                    </padding>
                    <children>
                        <StackPane maxHeight="32.0" maxWidth="32.0" minHeight="32.0" minWidth="32.0" prefHeight="32.0" prefWidth="32.0" styleClass="export-dialog-report-icon">
                            <children>
                                <VBox alignment="CENTER_LEFT" spacing="2.5" styleClass="export-dialog-report-paper">
                                    <children>
                                        <Region prefHeight="7.0" prefWidth="12.0" styleClass="export-dialog-report-accent" />
                                        <Region prefHeight="2.0" prefWidth="14.0" styleClass="export-dialog-report-line" />
                                        <Region prefHeight="2.0" prefWidth="11.0" styleClass="export-dialog-report-line" />
                                    </children>
                                </VBox>
                            </children>
                        </StackPane>
                        <Label text="Cetak Laporan" styleClass="export-dialog-title" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnClose" mnemonicParsing="false" onAction="#handleClose" text="X" styleClass="export-dialog-close" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" minHeight="132.0" prefHeight="132.0" spacing="16.0" styleClass="export-dialog-body">
                    <padding>
                        <Insets left="28.0" right="28.0" />
                    </padding>
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="Pilih format export laporan" styleClass="export-dialog-heading" />
                                <Label text="Pilih format file yang ingin dibuat." styleClass="export-dialog-subtitle" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <StackPane maxHeight="48.0" maxWidth="48.0" minHeight="48.0" minWidth="48.0" prefHeight="48.0" prefWidth="48.0" styleClass="export-dialog-help">
                            <children>
                                <Label text="?" styleClass="export-dialog-help-text" />
                            </children>
                        </StackPane>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" minHeight="92.0" prefHeight="92.0" spacing="14.0" styleClass="export-dialog-footer">
                    <padding>
                        <Insets left="26.0" right="26.0" />
                    </padding>
                    <children>
                        <Button fx:id="btnPdf" mnemonicParsing="false" onAction="#handlePdf" prefHeight="42.0" prefWidth="160.0" styleClass="export-dialog-button-pdf">
                            <graphic>
                                <StackPane maxHeight="24.0" maxWidth="24.0" minHeight="24.0" minWidth="24.0" prefHeight="24.0" prefWidth="24.0" styleClass="export-button-icon-pdf">
                                    <children>
                                        <Label text="PDF" styleClass="export-button-icon-text" />
                                    </children>
                                </StackPane>
                            </graphic>
                            <text>Export ke PDF</text>
                        </Button>
                        <Button fx:id="btnExcel" mnemonicParsing="false" onAction="#handleExcel" prefHeight="42.0" prefWidth="175.0" styleClass="export-dialog-button-excel">
                            <graphic>
                                <StackPane maxHeight="24.0" maxWidth="24.0" minHeight="24.0" minWidth="24.0" prefHeight="24.0" prefWidth="24.0" styleClass="export-button-icon-excel">
                                    <children>
                                        <Label text="XLS" styleClass="export-button-icon-text" />
                                    </children>
                                </StackPane>
                            </graphic>
                            <text>Export ke Excel</text>
                        </Button>
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancel" prefHeight="42.0" prefWidth="125.0" styleClass="export-dialog-button-cancel" text="Batal" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
