                        <HBox fx:id="wrapperPengeluaran" alignment="CENTER_LEFT" prefHeight="45.0">
                            <children>
                                <Region fx:id="indPengeluaran" prefHeight="25.0" prefWidth="3.0" style="-fx-background-color: transparent; -fx-background-radius: 10;" />
                                <Button fx:id="btnKelolaPengeluaran" alignment="BASELINE_LEFT" onAction="#handleMenuAction" prefHeight="45.0" prefWidth="175.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-cursor: hand;" text="Kelola Pengeluaran">
                                    <graphic><ImageView fx:id="imgPengeluaran" fitHeight="20.0" fitWidth="20.0"><image><Image url="@../../Images/ICON11.png" /></image></ImageView></graphic>
