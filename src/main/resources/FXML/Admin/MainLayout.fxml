                            <children>
                                <Region fx:id="indDashboard" prefHeight="25.0" prefWidth="3.0" style="-fx-background-color: transparent; -fx-background-radius: 10;" />
                                <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" onAction="#handleMenuAction" prefHeight="45.0" prefWidth="175.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-cursor: hand;" text="Dashboard">
                                    <graphic><ImageView fx:id="imgDashboard" fitHeight="20.0" fitWidth="20.0"><image><Image url="@../../Images/icon39.png" /></image></ImageView></graphic>
                                    <padding><Insets left="15.0" /></padding>
                                </Button>
                            </children>
                        </HBox>

                        <HBox fx:id="wrapperTransaksi" alignment="CENTER_LEFT" prefHeight="45.0">
                            <children>
                                <Region fx:id="indTransaksi" prefHeight="25.0" prefWidth="3.0" style="-fx-background-color: transparent; -fx-background-radius: 10;" />
                                <Button fx:id="btnTransaksi" alignment="BASELINE_LEFT" onAction="#handleMenuAction" prefHeight="45.0" prefWidth="175.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-cursor: hand;" text="Transaksi">
                                    <graphic><ImageView fx:id="imgTransaksi" fitHeight="20.0" fitWidth="20.0"><image><Image url="@../../Images/ICON5.png" /></image></ImageView></graphic>
                                    <padding><Insets left="15.0" /></padding>
                                </Button>
                            </children>
                        </HBox>

                        <HBox fx:id="wrapperDataBarang" alignment="CENTER_LEFT" prefHeight="45.0">
                            <children>
                                <Region fx:id="indDataBarang" prefHeight="25.0" prefWidth="3.0" style="-fx-background-color: transparent; -fx-background-radius: 10;" />
                                <Button fx:id="btnDataBarang" alignment="BASELINE_LEFT" onAction="#handleMenuAction" prefHeight="45.0" prefWidth="175.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-cursor: hand;" text="Data Barang">
                                    <graphic><ImageView fx:id="imgDataBarang" fitHeight="20.0" fitWidth="23.0"><image><Image url="@../../Images/ICON8.png" /></image></ImageView></graphic>
                                    <padding><Insets left="15.0" /></padding>
                                </Button>
                            </children>
                        </HBox>

                        <HBox fx:id="wrapperLaporan" alignment="CENTER_LEFT" prefHeight="45.0">
                            <children>
                                <Region fx:id="indLaporan" prefHeight="25.0" prefWidth="3.0" style="-fx-background-color: transparent; -fx-background-radius: 10;" />
                                <Button fx:id="btnLaporan" alignment="BASELINE_LEFT" onAction="#handleMenuAction" prefHeight="45.0" prefWidth="175.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-cursor: hand;" text="Laporan">
                                    <graphic><ImageView fx:id="imgLaporan" fitHeight="20.0" fitWidth="20.0"><image><Image url="@../../Images/ICON9.png" /></image></ImageView></graphic>
