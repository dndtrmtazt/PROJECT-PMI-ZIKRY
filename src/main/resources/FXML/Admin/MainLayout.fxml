                                <Button fx:id="btnDataKategori" alignment="BASELINE_LEFT" onAction="#handleMenuAction" prefHeight="45.0" prefWidth="175.0" style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-cursor: hand;" text="Data Kategori">
                                    <graphic><ImageView fx:id="imgKategori" fitHeight="20.0" fitWidth="20.0"><image><Image url="@../../Images/ICON10.png" /></image></ImageView></graphic>
