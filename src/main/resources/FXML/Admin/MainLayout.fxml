                <Region prefHeight="156.0" prefWidth="182.0" VBox.vgrow="ALWAYS" />

                <HBox fx:id="hboxThemeToggle" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="32.0" prefWidth="90.0" spacing="2.0" style="-fx-background-color: #F9FAFB; -fx-background-radius: 20; -fx-border-color: #D1D5DB; -fx-border-radius: 20; -fx-border-width: 1;">
                    <children>
                        <Button fx:id="btnLightMode" mnemonicParsing="false" onAction="#handleThemeChange" prefHeight="21.0" prefWidth="43.0" style="-fx-background-color: #efefef; -fx-background-radius: 20; -fx-cursor: hand;">
                            <graphic>
                                <ImageView fx:id="imgLightMode" fitHeight="39.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../Images/ICON3.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button fx:id="btnDarkMode" mnemonicParsing="false" onAction="#handleThemeChange" prefHeight="26.0" prefWidth="38.0" style="-fx-background-color: transparent; -fx-background-radius: 18; -fx-cursor: hand;">
