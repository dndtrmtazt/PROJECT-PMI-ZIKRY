                                <ImageView fx:id="imgDarkMode" fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../Images/ICON4.png" /></image>
                                </ImageView>
                            </graphic>
