<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootPane" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.TambahUserController">
    <children>
        <Label fx:id="lblFormTitle" style="-fx-font-weight: bold; -fx-font-size: 18;" text="Tambah User" />
        <GridPane hgap="10.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints minWidth="100.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="30.0" />
                <RowConstraints minHeight="30.0" />
                <RowConstraints minHeight="30.0" />
                <RowConstraints minHeight="30.0" />
            </rowConstraints>
            <children>
                <Label text="Nama" />
                <TextField fx:id="txtNama" promptText="Masukkan nama" GridPane.columnIndex="1" />
                <Label text="ID User" GridPane.rowIndex="1" />
                <TextField fx:id="txtID" promptText="Masukkan id user" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Label text="Password" GridPane.rowIndex="2" />
                <PasswordField fx:id="txtPass" promptText="Masukkan password" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <Label text="Role" GridPane.rowIndex="3" />
                <ComboBox fx:id="cbRole" prefWidth="200.0" promptText="Select" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </children>
        </GridPane>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button fx:id="btnBatal" onAction="#handleBatal" style="-fx-background-color: #E0E0E0;" text="Batal" />
                <Button fx:id="btnSimpan" onAction="#handleSimpan" style="-fx-background-color: #4A90E2; -fx-text-fill: white;" text="Simpan" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
