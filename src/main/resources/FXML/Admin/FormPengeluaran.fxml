<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootPane" prefWidth="400.0" spacing="20.0" styleClass="admin-page-root" stylesheets="@../../CSS/admin.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.FormPengeluaranController">
    <children>
        <HBox alignment="CENTER" prefHeight="50.0" styleClass="admin-header">
            <children>
                <Label fx:id="lblHeader" styleClass="admin-title" text="Form Data Pengeluaran">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
            </children>
        </HBox>

        <VBox spacing="15.0">
            <padding>
                <Insets bottom="20.0" left="25.0" right="25.0" top="10.0" />
            </padding>
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="admin-label" text="ID Pengeluaran" />
                        <TextField fx:id="txtId" editable="false" promptText="Contoh: PGN001" styleClass="admin-input" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="admin-label" text="Tanggal" />
                        <DatePicker fx:id="dpTanggal" prefWidth="350.0" styleClass="admin-date-picker" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="admin-label" text="Nominal (Rp)" />
                        <TextField fx:id="txtNominal" promptText="Contoh: 50000" styleClass="admin-input" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="admin-label" text="Jenis Pengeluaran" />
                        <TextField fx:id="txtJenis" promptText="Contoh: Listrik / Bahan Baku" styleClass="admin-input" />
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button fx:id="btnBatal" onAction="#handleBatal" prefHeight="30.0" prefWidth="80.0" styleClass="admin-button-neutral" text="Batal" />
                        <Button fx:id="btnSimpan" onAction="#handleSimpan" prefHeight="30.0" prefWidth="100.0" styleClass="admin-button-success" text="Simpan" />
                    </children>
                    <padding>
                        <Insets top="10.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
