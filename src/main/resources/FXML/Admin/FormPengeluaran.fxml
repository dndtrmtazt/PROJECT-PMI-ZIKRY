<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootPane" prefWidth="400.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 10;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.FormPengeluaranController">
    <children>
        <HBox alignment="CENTER" prefHeight="50.0" style="-fx-background-color: #4A76A8; -fx-background-radius: 10 10 0 0;">
            <children>
                <Label fx:id="lblHeader" text="Form Data Pengeluaran" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
            </children>
        </HBox>

        <VBox spacing="15.0">
            <padding>
                <Insets bottom="20.0" left="25.0" right="25.0" top="10.0" />
            </padding>
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label text="ID Pengeluaran" />
                        <TextField fx:id="txtId" editable="true" promptText="Contoh: PGN001" style="-fx-background-color: white; -fx-border-color: #DCDCDC; -fx-border-radius: 5; -fx-background-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Tanggal" />
                        <DatePicker fx:id="dpTanggal" prefWidth="350.0" style="-fx-background-radius: 5; -fx-border-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Nominal (Rp)" />
                        <TextField fx:id="txtNominal" promptText="Contoh: 50000" style="-fx-background-color: white; -fx-border-color: #DCDCDC; -fx-border-radius: 5; -fx-background-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Jenis Pengeluaran" />
                        <TextField fx:id="txtJenis" promptText="Contoh: Listrik / Bahan Baku" style="-fx-background-color: white; -fx-border-color: #DCDCDC; -fx-border-radius: 5; -fx-background-radius: 5;" />
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button fx:id="btnBatal" onAction="#handleBatal" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: #BDC3C7; -fx-text-fill: #000000 ; -fx-cursor: hand;" text="Batal" />
                        <Button fx:id="btnSimpan" onAction="#handleSimpan" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Simpan" />
                    </children>
                    <padding>
                        <Insets top="10.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
