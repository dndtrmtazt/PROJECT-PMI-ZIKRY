<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="paneRoot" prefHeight="600.0" prefWidth="817.0" styleClass="admin-page-root" stylesheets="@../../CSS/admin.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.KategoriController">
    <children>
        <HBox fx:id="vboxHeader" alignment="CENTER_LEFT" maxHeight="60.0" minHeight="60.0" prefHeight="60.0" styleClass="admin-header">
            <children>
                <Label fx:id="lblTitle" styleClass="admin-title" text="Data Kategori">
                    <font><Font name="System Bold" size="24.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Label>
            </children>
        </HBox>

        <VBox minHeight="0.0" spacing="20.0" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="20.0" left="25.0" right="25.0" top="20.0" /></padding>
            <children>
                <HBox fx:id="hboxSearch" alignment="CENTER_LEFT" maxHeight="80.0" minHeight="80.0" prefHeight="80.0" spacing="15.0" styleClass="admin-search-card">
                    <padding><Insets left="20.0" right="20.0" /></padding>
                    <children>
                        <TextField fx:id="txtSearchKategori" prefHeight="35.0" prefWidth="600.0" promptText="Cari Kategori..." styleClass="admin-input" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnSearchKategori" onAction="#handleSearchKategori" prefHeight="35.0" prefWidth="150.0" styleClass="admin-button-primary" text="Temukan Kategori" />
                    </children>
                </HBox>

                <VBox fx:id="vboxContent" minHeight="0.0" spacing="15.0" styleClass="admin-table-card" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" maxHeight="35.0" minHeight="35.0" prefHeight="35.0">
                            <children>
                                <Label fx:id="lblDaftarKategori" styleClass="admin-section-title" text="Daftar Kategori" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnTambah"
                                        maxHeight="35.0"
                                        maxWidth="220.0"
                                        minHeight="35.0"
                                        minWidth="220.0"
                                        mnemonicParsing="false"
                                        onAction="#handleTambahKategori"
                                        prefHeight="35.0"
                                        prefWidth="220.0"
                                        styleClass="admin-button-success"
                                        text="+ Tambahkan Data Kategori">
                                </Button>
                            </children>
                        </HBox>

                        <HBox fx:id="hboxTableHead" alignment="CENTER_LEFT" maxHeight="40.0" minHeight="40.0" prefHeight="40.0" spacing="10.0" styleClass="admin-table-head">
                            <padding><Insets left="15.0" right="15.0" /></padding>
                            <children>
                                <Label prefWidth="91.0" style="-fx-font-weight: bold;" text="No" />
                                <Label prefWidth="199.0" style="-fx-font-weight: bold;" text="ID Kategori" />
                                <Label prefWidth="236.0" style="-fx-font-weight: bold;" text="Nama Kategori" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label alignment="CENTER" prefWidth="180.0" style="-fx-font-weight: bold;" text="Aksi" />
                            </children>
                        </HBox>

                        <ScrollPane fx:id="scrollKategori" fitToWidth="true" hbarPolicy="NEVER" minHeight="0.0" styleClass="admin-list-scroll" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="vboxKategoriList" spacing="0.0" style="-fx-background-color: transparent;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
