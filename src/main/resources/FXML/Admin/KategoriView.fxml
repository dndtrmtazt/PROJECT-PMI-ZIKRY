<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="paneRoot" prefHeight="600.0" prefWidth="817.0" style="-fx-background-color: #F4F4F4;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.KategoriController">
    <children>
        <HBox fx:id="vboxHeader" alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #4A76A8;">
            <children>
                <Label fx:id="lblTitle" text="Data Kategori" textFill="WHITE">
                    <font><Font name="System Bold" size="24.0" /></font>
                    <padding><Insets left="20.0" /></padding>
                </Label>
            </children>
        </HBox>

        <VBox spacing="20.0" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="20.0" left="25.0" right="25.0" top="20.0" /></padding>
            <children>
                <HBox fx:id="hboxSearch" alignment="CENTER_LEFT" prefHeight="80.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                    <padding><Insets left="20.0" right="20.0" /></padding>
                    <children>
                        <TextField fx:id="txtSearchKategori" prefHeight="35.0" prefWidth="600.0" promptText="Cari Kategori..." style="-fx-background-radius: 8;" HBox.hgrow="ALWAYS" />
                        <Button prefHeight="35.0" prefWidth="140.0" style="-fx-background-color: #4A76A8; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-family: 'Inter Medium';" text="Temukan Kategori" />
                    </children>
                </HBox>

                <VBox fx:id="vboxContent" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label fx:id="lblDaftarKategori" style="-fx-font-family: 'Inter Medium'; -fx-font-size: 18; -fx-font-weight: bold;" text="Daftar Kategori" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnTambah" mnemonicParsing="false" onAction="#handleTambahKategori" prefHeight="35.0" prefWidth="220.0" style="-fx-background-color: #5CB85C; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-family: 'Inter Medium';" text="+ Tambahkan Data Kategori">
                                </Button>
                            </children>
                        </HBox>

                        <HBox fx:id="hboxTableHead" alignment="CENTER_LEFT" prefHeight="40.0" spacing="10.0" style="-fx-background-color: #F8FAFC; -fx-background-radius: 5; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
                            <padding><Insets left="15.0" right="15.0" /></padding>
                            <children>
                                <Label prefWidth="91.0" style="-fx-font-weight: bold;" text="No" />
                                <Label prefWidth="199.0" style="-fx-font-weight: bold;" text="ID Kategori" />
                                <Label prefWidth="236.0" style="-fx-font-weight: bold;" text="Nama Kategori" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label alignment="CENTER" prefWidth="180.0" style="-fx-font-weight: bold;" text="Aksi" />
                            </children>
                        </HBox>

                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="vboxKategoriList" spacing="0.0" style="-fx-background-color: transparent;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
