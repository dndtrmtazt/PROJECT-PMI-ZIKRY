<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="dialogRoot" styleClass="admin-delete-dialog-root" stylesheets="@../../CSS/admin.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ConfirmDeleteDialogController">
    <children>
        <VBox minWidth="460.0" prefWidth="460.0" maxWidth="460.0" styleClass="admin-delete-dialog-card">
            <children>
                <HBox alignment="TOP_LEFT" spacing="12.0" styleClass="admin-delete-dialog-body">
                    <children>
                        <StackPane styleClass="admin-delete-dialog-icon">
                            <children>
                                <Label text="!" styleClass="admin-delete-dialog-icon-text" />
                            </children>
                        </StackPane>

                        <VBox alignment="TOP_LEFT" spacing="12.0">
                            <children>
                                <Label fx:id="lblTitle" text="Konfirmasi Hapus?" styleClass="admin-delete-dialog-title" />
                                <Label fx:id="lblMessage" maxWidth="320.0" text="Anda yakin ingin menghapus data ini?" wrapText="true" styleClass="admin-delete-dialog-message" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="btnClose" mnemonicParsing="false" onAction="#handleClose" text="X" styleClass="admin-delete-dialog-close">
                            <HBox.margin>
                                <Insets top="-12.0" right="-2.0" />
                            </HBox.margin>
                        </Button>
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="18.0" styleClass="admin-delete-dialog-footer">
                    <children>
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancel" text="Batal" styleClass="admin-delete-dialog-cancel" />
                        <Button fx:id="btnConfirm" mnemonicParsing="false" onAction="#handleConfirm" text="Hapus" styleClass="admin-delete-dialog-confirm" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
