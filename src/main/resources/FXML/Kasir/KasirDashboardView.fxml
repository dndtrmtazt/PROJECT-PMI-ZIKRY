<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="paneRoot" minHeight="600.0" minWidth="900.0" prefHeight="600.0" prefWidth="953.0" style="-fx-background-color: #efefef;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.KasirDashboardController">
    <children>
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox fx:id="vboxSidebar" maxWidth="160.0" minWidth="160.0" prefWidth="160.0" style="-fx-background-color: #f8f8f8; -fx-border-color: #d9d9d9; -fx-border-width: 0 1 0 0;">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="72.0" spacing="8.0">
                            <padding><Insets bottom="10.0" left="12.0" right="10.0" top="16.0" /></padding>
                            <children>
                                <ImageView fx:id="imgLogo" fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                                    <image><Image url="@../../Images/LOGO.png" /></image>
                                </ImageView>
                                <Label fx:id="lblLogo" style="-fx-font-weight: bold; -fx-text-fill: #111111;" text="Toko Zikry">
                                    <font><Font size="15.0" /></font>
                                </Label>
                            </children>
                        </HBox>

                        <VBox spacing="8.0">
                            <padding><Insets bottom="0.0" left="10.0" right="10.0" top="6.0" /></padding>
                            <children>
                                <Button fx:id="btnTransaksi" alignment="CENTER_LEFT" graphicTextGap="6.0" mnemonicParsing="false" prefHeight="38.0" prefWidth="126.0" style="-fx-background-color: #dce9f7; -fx-background-radius: 10; -fx-text-fill: #3b6ea7; -fx-font-size: 12px; -fx-padding: 0 0 0 10;">
                                    <graphic>
                                        <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                            <image><Image url="@../../Images/ICON5.png" /></image>
                                        </ImageView>
                                    </graphic>
                                    <text>Transaksi</text>
                                </Button>
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <VBox spacing="14.0">
                            <padding><Insets bottom="16.0" left="12.0" right="12.0" top="0.0" /></padding>
                            <children>
                                <HBox fx:id="hboxThemeToggle" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="32.0" prefWidth="90.0" spacing="2.0" style="-fx-background-color: white; -fx-border-color: #cfcfcf; -fx-border-radius: 20; -fx-background-radius: 20;">
                                    <children>
                                        <Button fx:id="btnLightMode" mnemonicParsing="false" prefHeight="26.0" prefWidth="38.0" style="-fx-background-color: #efefef; -fx-background-radius: 18; -fx-cursor: hand;">
                                            <graphic><ImageView fx:id="imgLightMode" fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../../Images/ICON3.png" /></image></ImageView></graphic>
                                        </Button>
                                        <Button fx:id="btnDarkMode" mnemonicParsing="false" prefHeight="26.0" prefWidth="38.0" style="-fx-background-color: transparent; -fx-background-radius: 18; -fx-cursor: hand;">
                                            <graphic><ImageView fx:id="imgDarkMode" fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../../Images/ICON4.png" /></image></ImageView></graphic>
                                        </Button>
                                    </children>
                                </HBox>
                                <Button fx:id="btnLogout" alignment="CENTER" graphicTextGap="6.0" mnemonicParsing="false" prefHeight="28.0" prefWidth="100.0" style="-fx-background-color: transparent; -fx-text-fill: #111111; -fx-font-size: 12px; -fx-padding: 0;">
                                    <graphic><ImageView fx:id="imgLogout" fitHeight="28.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true"><image><Image url="@../../Images/ICON6.png" /></image></ImageView></graphic>
                                    <text>Log Out</text>
                                </Button>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox fx:id="vboxMainContent" minWidth="740.0" prefHeight="600.0" prefWidth="1023.0" style="-fx-background-color: #efefef;" HBox.hgrow="ALWAYS">
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
