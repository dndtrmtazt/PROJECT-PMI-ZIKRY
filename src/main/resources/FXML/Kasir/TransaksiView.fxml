<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="paneRoot" prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #efefef;" stylesheets="@../../CSS/kasir-scroll.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.KasirDashboardController">
    <children>
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox fx:id="vboxMainContent" spacing="15.0" style="-fx-background-color: #efefef;" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="15.0" left="20.0" right="20.0" top="15.0" /></padding>
                    <children>

                        <HBox alignment="CENTER_RIGHT" prefHeight="24.0">
                            <children>
                                <Label fx:id="lblTanggal" style="-fx-text-fill: #111111;" text="Minggu, 26 Apr 2026 | 02:50 WITA">
                                    <font><Font size="13.0" /></font>
                                </Label>
                            </children>
                        </HBox>

                        <HBox prefHeight="597.0" prefWidth="866.0" spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox fx:id="hboxSearch" alignment="CENTER_LEFT" prefHeight="50.0" spacing="12.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #d3d3d3; -fx-border-radius: 10;">
                                            <padding><Insets left="15.0" right="15.0" /></padding>
                                            <children>
                                                <Label fx:id="lblSearchIcon" style="-fx-text-fill: #9a9a9a;" text="🔍"><font><Font size="18.0" /></font></Label>
                                                <TextField fx:id="txtSearch" promptText="Cari Produk / kode barang..." style="-fx-background-color: transparent; -fx-font-size: 15px;" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>

                                        <VBox fx:id="vboxProductCard" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #d7d7d7; -fx-border-radius: 10;" VBox.vgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="lblListProduk" style="-fx-font-weight: bold; -fx-text-fill: #111111;" text="List Produk">
                                                    <font><Font size="20.0" /></font>
                                                    <padding><Insets bottom="15.0" left="20.0" top="15.0" /></padding>
                                                </Label>
                                                <HBox fx:id="hboxProductHeader" alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-background-color: #e0e0e0;">
                                                    <padding><Insets left="20.0" right="20.0" /></padding>
                                                    <children>
                                                        <Label fx:id="lblHeaderNama" maxWidth="1.7976931348623157E308" style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Nama Produk" HBox.hgrow="ALWAYS"><font><Font size="14.0" /></font></Label>
                                                        <Label fx:id="lblHeaderStok" alignment="CENTER" minWidth="80.0" prefWidth="80.0" style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Stok"><font><Font size="14.0" /></font></Label>
                                                        <Label fx:id="lblHeaderHarga" alignment="CENTER_LEFT" minWidth="150.0" prefWidth="150.0" style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Harga"><padding><Insets left="15.0" /></padding><font><Font size="14.0" /></font></Label>
                                                        <Region minWidth="120.0" prefWidth="120.0" />
                                                        <Region minWidth="15.0" prefWidth="15.0" />
                                                    </children>
                                                </HBox>
                                                <ScrollPane fx:id="scrollProduct" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                                                    <content>
                                                        <VBox fx:id="vboxProdukList" style="-fx-background-color: transparent;" />
                                                    </content>
                                                </ScrollPane>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox fx:id="vboxCart" maxWidth="400.0" minWidth="400.0" prefWidth="400.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #d7d7d7; -fx-border-radius: 10;">
                                    <children>
                                        <Label fx:id="lblKeranjangBelanja" style="-fx-font-weight: bold; -fx-text-fill: #111111;" text="Keranjang Belanja">
                                            <font><Font size="18.0" /></font>
                                            <padding><Insets bottom="15.0" left="15.0" top="15.0" /></padding>
                                        </Label>
                                        <HBox fx:id="hboxCartHeader" alignment="CENTER_LEFT" minHeight="45.0" style="-fx-background-color: #e0e0e0;">
                                            <padding><Insets left="15.0" right="15.0" /></padding>
                                            <children>
                                                <Label fx:id="lblCartHeaderItem" maxWidth="1.7976931348623157E308" minWidth="60.0" style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Item" HBox.hgrow="ALWAYS"><font><Font size="13.0" /></font></Label>
                                                <Label fx:id="lblCartHeaderQty" alignment="CENTER" minWidth="80.0" prefWidth="80.0" style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Qty"><font><Font size="13.0" /></font></Label>
                                                <Label fx:id="lblCartHeaderHarga" alignment="CENTER_RIGHT" minWidth="90.0" prefWidth="90.0" style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Harga"><font><Font size="13.0" /></font></Label>
                                                <Label fx:id="lblCartHeaderSubtotal" alignment="CENTER_RIGHT" minWidth="90.0" prefWidth="90.0" style="-fx-font-weight: bold; -fx-text-fill: #333333;" text="Subtotal"><font><Font size="13.0" /></font></Label>
                                                <Region minWidth="15.0" prefWidth="15.0" />
                                            </children>
                                        </HBox>

                                        <ScrollPane fx:id="scrollCart" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                                            <content>
                                                <VBox fx:id="vboxCartList" style="-fx-background-color: transparent;" />
                                            </content>
                                        </ScrollPane>

                                        <VBox fx:id="vboxSummary" maxHeight="210.0" minHeight="210.0" prefHeight="210.0" spacing="15.0" style="-fx-border-color: #e0e0e0 transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label fx:id="lblTotalBelanjaText" style="-fx-font-weight: bold;" text="Total Belanja:"><font><Font size="15.0" /></font></Label>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="lblTotalBelanja" style="-fx-font-weight: bold;" text="Rp 0"><font><Font size="18.0" /></font></Label>
                                                    </children>
                                                </HBox>
                                                <TextField fx:id="txtBayar" prefHeight="45.0" promptText="Masukkan Nominal Bayar" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #d3d3d3; -fx-font-size: 15px;" />
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label fx:id="lblKembalianText" style="-fx-font-weight: bold;" text="Kembalian:"><font><Font size="15.0" /></font></Label>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="lblKembalian" style="-fx-font-weight: bold;" text="Rp 0"><font><Font size="18.0" /></font></Label>
                                                    </children>
                                                </HBox>
                                                <Button fx:id="btnSimpanCetak" mnemonicParsing="false" onAction="#handleCheckout" prefHeight="50.0" prefWidth="1.7976931348623157E308" style="-fx-background-color: #5cb85c; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand;" text="Simpan &amp; Cetak" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
